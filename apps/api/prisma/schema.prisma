  criadoPor    String?

  ocorrencia PreOcupacaoOcorrencia           @relation(fields: [ocorrenciaId], references: [id], onDelete: Cascade)
  andamento  PreOcupacaoOcorrenciaAndamento? @relation(fields: [andamentoId], references: [id], onDelete: SetNull)

  @@index([ocorrenciaId])
  @@index([andamentoId])
  @@map("pre_ocupacao_ocorrencia_anexos")
}

