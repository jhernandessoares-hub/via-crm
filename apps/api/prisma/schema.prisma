// ─── Gestão de Empreendimentos ───────────────────────────────────────────────

model Development {
  id                  String    @id @default(uuid())
  tenantId            String
  nome                String
  tipo                String // VERTICAL | HORIZONTAL
  subtipo             String // APARTAMENTO | CASA | LOTEAMENTO
  endereco            String?
  cidade              String?
  estado              String?
  sunOrientation      String    @default("LESTE") // NORTE | SUL | LESTE | OESTE
  prazoEntrega        DateTime?
  status              String    @default("LANCAMENTO") // LANCAMENTO | EM_OBRA | CONCLUIDO
  gridRows            Int       @default(10)
  gridCols            Int       @default(10)
  gridLayout          Json?
  descricao           String?
  lat                 Float? // GPS latitude do centro do terreno
  lng                 Float? // GPS longitude do centro do terreno
  entranceLat         Float? // GPS latitude da entrada principal (usado pelo Street View 3D)
  entranceLng         Float? // GPS longitude da entrada principal
  implantacaoUrl      String? // URL Cloudinary da planta de implantação
  implantacaoPublicId String? // Cloudinary public ID para delete
  implantacaoMode     String? // SATELITE | IMAGEM — modo de posicionamento das torres
  capaUrl             String? // URL da foto de capa do card na listagem
  terrainDesign       Json? // Desenho do terreno: { version, shapes: [{id, type, points, ...}] }
  modelUrl            String? // URL Cloudinary do modelo 3D do arquiteto (.glb/.gltf)
  modelPublicId       String? // Cloudinary public ID do modelo 3D para delete
  areasComuns         Json? // { piscina, academia, playground, jardim, portaria } (boolean flags)
  publishedAt         DateTime? // null = rascunho (visível só para OWNER); preenchido = publicado para todo o tenant
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  tenant           Tenant                       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  towers           Tower[]
  units            DevelopmentUnit[]
  paymentCondition DevelopmentPaymentCondition?
  mediaItems       DevelopmentMedia[]
  obraUpdates      DevelopmentObraUpdate[]
  leadInteresses   Lead[]                       @relation("LeadEmpreendimentoInteresse")

  @@index([tenantId])
  @@map("developments")
}

model Tower {
  id                   String   @id @default(uuid())
  developmentId        String
  tenantId             String
  nome                 String
  floors               Int      @default(1)
  unitsPerFloor        Int      @default(1)
  gridX                Int?
  gridY                Int?
  gridWidth            Int      @default(1)
  gridHeight           Int      @default(1)
  offsetX              Float    @default(0) // metros do centro do desenvolvimento (eixo E-W)
  offsetY              Float    @default(0) // metros do centro (eixo N-S)
  larguraM             Float    @default(20) // largura da torre/quadra em metros
  profundidadeM        Float    @default(15) // profundidade em metros
  alturaAndarM         Float    @default(3.0) // altura por andar (VERTICAL) ou da casa (HORIZONTAL)
  rotacao              Float    @default(0) // rotação em graus
  lados                String   @default("FRENTE,FUNDO,ESQUERDA,DIREITA") // faces com unidades
  facadeImageUrl       String? // URL da imagem de textura da fachada
  roofType             String?  @default("FLAT") // FLAT, GABLED, PYRAMID
  roofColor            String?  @default("#808080") // Cor do telhado
  facadeColor          String?  @default("#e5e7eb") // Cor da fachada (hex)
  balconyType          String?  @default("NONE") // NONE | JULIET | SLAB | GLASS | FRENCH
  floorPlan            Json? // Planta do andar: {cols, rows, cells:[APT|HALL|EMPTY], cellWidthM, cellDepthM}
  hasLobbyFloor        Boolean  @default(false) // Térreo sem apartamentos (só hall/entrada)
  // Implantação modo IMAGEM — coordenadas relativas (0..1) sobre a imagem de implantação
  implantacaoX         Float?
  implantacaoY         Float?
  implantacaoW         Float?
  implantacaoH         Float?
  // Implantação modo SATELITE — coordenadas GPS reais da torre
  implantacaoLat       Float?
  implantacaoLng       Float?
  ladoConfig           Json? // legado — { "1": "Norte", "2": "Sul" }
  subsolos             Int      @default(0)
  floorUnitsConfig     Json? // legado — { "-1": 4 }
  fasesConfig          Json? // [{ "nome": "Sul", "unidades": 4, "subsolos": 2 }, ...]
  posicaoPad           Int      @default(2) // dígitos do sufixo: 1=>"11", 2=>"101", 3=>"1001", 4=>"10001"
  posicaoFinalMap      Json? // array de finais por posição global: [3,1,4,...] = posição 1→final 3
  prefixoUnidade       String?  @default("") // prefixo antes do código: "Apto", "AP", "" (nenhum)
  andarInicialContagem String?  @default("PRIMEIRO_PAV") // "SUBSOLO" | "TERREO" | "PRIMEIRO_PAV"
  andarInicialDisplay  Int?     @default(1) // número exibido para o primeiro andar contado
  subsoloDisplay       String?  @default("PREFIXO_S") // "PREFIXO_S" | "SEQUENCIAL" | "PAV_INFERIOR"
  terreoConfig         String?  @default("NUMERICO") // "SEM_APTO" | "NUMERICO" | "TERREO_LABEL"
  terreoLabelText      String?  @default("T") // label do térreo quando terreoConfig = "TERREO_LABEL"
  rotuloAcima          String?  @default("NUMERO_PURO") // rótulo dos andares acima: "NUMERO_PURO" | "PAV" | "ANDAR"
  prefixoContagem      String?  @default("DERIVADO_ROTULO") // como calcular o prefixo numérico da unidade: "DERIVADO_ROTULO" | "SEQUENCIAL_TOTAL"
  blocoIdentificador   String?  @default("") // identificador do bloco/torre no código: "A", "B", "1", "BL A"
  blocoPosition        String?  @default("NENHUM") // posição do bloco no código: "NENHUM" | "INICIO" | "MEIO" | "FIM"
  blocoSeparador       String?  @default("") // separador entre bloco e número: "", " ", "-"
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  development Development       @relation(fields: [developmentId], references: [id], onDelete: Cascade)
  units       DevelopmentUnit[]

  @@index([developmentId])
  @@map("towers")
}

model DevelopmentUnit {
  id                String    @id @default(uuid())
  towerId           String
  developmentId     String
  tenantId          String
  nome              String
  andar             Int?
  posicao           Int?
  status            String    @default("DISPONIVEL") // DISPONIVEL | PROPOSTA | RESERVADO | VENDIDO | BLOQUEADO
  bloqueioMotivo    String?
  areaM2            Float?
  quartos           Int?
  suites            Int?
  banheiros         Int?
  vagas             Int?
