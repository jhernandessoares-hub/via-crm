// ============================================================================
// Pré-Ocupação (TTS — Trabalho Técnico Social) — exclusivo tenant SP9
// ============================================================================
// "Família" = o Lead de venda já existente (FK única). "Atividade" = uma sessão
// agendada (nasce como CalendarEvent) onde várias famílias participam juntas;
// cada família tem seu próprio registro de preenchimento via
// PreOcupacaoAtividadeParticipante. Entregáveis Mensais são 100% agregados
// (não duplicam upload) a partir das sessões/participantes filtrando por
// competência.

model PreOcupacaoFamilia {
  id           String                   @id @default(uuid())
  tenantId     String
  leadId       String                   @unique
  numero       Int
  status       PreOcupacaoFamiliaStatus @default(ATIVA)
  ativadoEm    DateTime                 @default(now())
  ativadoPor   String
  criadoEm     DateTime                 @default(now())
  atualizadoEm DateTime                 @updatedAt

  lead          Lead                               @relation(fields: [leadId], references: [id], onDelete: Restrict)
  tenant        Tenant                             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  participacoes PreOcupacaoAtividadeParticipante[]
  ocorrencias   PreOcupacaoOcorrencia[]
  sessions      PreOcupacaoFamiliaSession[]

  @@unique([tenantId, numero])
  @@index([tenantId, status])
  @@map("pre_ocupacao_familias")
}

// Sessão do portal de login das famílias (CPF + últimos 4 dígitos do telefone).
// jti é o identificador do JWT emitido no login; revogar aqui invalida
// o acesso mesmo com token ainda não expirado (ex.: família virou INATIVA).
model PreOcupacaoFamiliaSession {
  id         String    @id @default(uuid())
  jti        String    @unique
  familiaId  String
  expiresAt  DateTime
  revokedAt  DateTime?
  criadoEm   DateTime  @default(now())

  familia PreOcupacaoFamilia @relation(fields: [familiaId], references: [id], onDelete: Cascade)

  @@index([familiaId])
  @@map("pre_ocupacao_familia_sessions")
}

// Conteúdo educacional (vídeo/imagem/apresentação) subido pela equipe e exibido
// na área logada da família (Portal Família). Armazenamento público no Cloudinary
// (não é dado pessoal/LGPD como os anexos de demanda/atividade).
model PreOcupacaoConteudo {
  id           String   @id @default(uuid())
  tenantId     String
  titulo       String
  descricao    String?
  url          String
  publicId     String
  mimeType     String?
  oculto       Boolean  @default(false)
  criadoPor    String
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, oculto])
  @@map("pre_ocupacao_conteudos")
}

model PreOcupacaoAtividade {
  id                     String                        @id @default(uuid())
  tenantId               String
  categoria              PreOcupacaoAtividadeCategoria
  calendarEventId        String?                       @unique
  dataAgendada           DateTime
  local                  String?
  titulo                 String?
  prazoPreenchimentoDias Int                           @default(5)
  relatorio              String?
  criadoEm               DateTime                      @default(now())
  atualizadoEm           DateTime                      @updatedAt

  tenant        Tenant                             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  calendarEvent CalendarEvent?                     @relation(fields: [calendarEventId], references: [id], onDelete: SetNull)
  anexos        PreOcupacaoAtividadeAnexo[]
  participantes PreOcupacaoAtividadeParticipante[]

  @@index([tenantId, categoria])
  @@index([tenantId, dataAgendada])
  @@map("pre_ocupacao_atividades")
}

model PreOcupacaoAtividadeAnexo {
