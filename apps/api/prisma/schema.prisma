generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Pipeline {
  id        String          @id @default(uuid())
  tenantId  String
  key       String
  name      String
  isActive  Boolean         @default(true)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  leads     Lead[]
  stages    PipelineStage[]
  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key], name: "tenantId_key")
  @@index([tenantId, isActive])
  @@map("pipelines")
}

model PipelineStage {
  id         String    @id @default(uuid())
  tenantId   String
  pipelineId String
  key        String
  name       String
  sortOrder  Int
  group      String?
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  leads      Lead[]
  pipeline   Pipeline  @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  slaRules   SlaRule[]

  @@unique([tenantId, pipelineId, key], name: "tenantId_pipelineId_key")
  @@index([tenantId, pipelineId, isActive, sortOrder])
  @@map("pipeline_stages")
}

model Tenant {
  id                  String                  @id @default(uuid())
  nome                String
  slug                String                  @unique
  ativo               Boolean                 @default(true)
  plan                String                  @default("STARTER") // STARTER | PREMIUM
  autopilotEnabled    Boolean                 @default(true)
  businessHours       Json?
  outsideHoursMessage String?
  aiDelayMin          Int                     @default(5)
  aiDelayMax          Int                     @default(15)
  aiTypingEnabled     Boolean                 @default(true)
  aiHistoryLimit      Int                     @default(8)
  // Dados da imobiliária
  logradouro          String?
  numero              String?
  bairro              String?
  cep                 String?
  cidade              String?
  estado              String?
  site                String?
  redesSociais        String?
  proprietarioNome    String?
  proprietarioTelefone String?
  // WhatsApp por tenant (multi-tenant)
  whatsappPhoneNumberId String?
  whatsappToken         String?
  whatsappVerifyToken   String?
  // Permissões configuráveis por role
  permissionsConfig     Json?
  roundRobinConfig      Json?             // { incluirGerentes: bool, incluirOwner: bool }
  // Branding / White-label
  brandPalette          String?           // chave da paleta: "verde-via" | "azul-royal" | ...
  logoUrl               String?           // URL Cloudinary da logo customizada
  logoPublicId          String?           // publicId Cloudinary para deletar
  faviconUrl            String?           // URL Cloudinary do favicon customizado
  faviconPublicId       String?
  criadoEm            DateTime                @default(now())
  agentKnowledgeBases    AgentKnowledgeBase[]
  agentTools             AgentTool[]
  aiAgents               AiAgent[]
  aiExecutionLogs        AiExecutionLog[]
  baseFrias              BaseFria[]
  branches               Branch[]
  knowledgeBases         KnowledgeBase[]
  knowledgeBaseDocuments KnowledgeBaseDocument[]
  knowledgeBaseVideos    KnowledgeBaseVideo[]
  knowledgeBaseLinks     KnowledgeBaseLink[]
  kbTeachings            KbTeaching[]
  events                 LeadEvent[]
  leadSlas               LeadSla[]
  leadTransitionLogs     LeadTransitionLog[]
  leads                  Lead[]
  learnings              Learning[]
  reasons                ManagerDecisionReason[]
  reviews                ManagerReview[]
  pipelineStages         PipelineStage[]
  pipelines              Pipeline[]
  productDocuments       ProductDocument[]
  productImages          ProductImage[]
  productVideos          ProductVideo[]
  products               Product[]
  slaRules               SlaRule[]
  users                  User[]
  channels               Channel[]
  tenantSites            TenantSite[]
  leadDocuments          LeadDocument[]
  leadParticipantes      LeadParticipante[]

  @@map("tenants")
}

model Channel {
  id               String    @id @default(uuid())
  tenantId         String
  type             String    // META_ADS | GOOGLE_ADS | YOUTUBE | TIKTOK_ADS | PORTAL_ZAP | PORTAL_VIVAREAL | PORTAL_OLX | PORTAL_IMOVELWEB | SITE
  name             String
  active           Boolean   @default(true)
  webhookToken     String    @unique @default(cuid())
  webhookTokenHash String?   @unique  // HMAC-SHA256 do token para lookup seguro
  config           Json?
  monthlyBudget    Float?
  leadsCount       Int       @default(0)
  lastLeadAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, type])
  @@index([tenantId])
  @@index([webhookToken])
  @@map("channels")
}

model Branch {
  id       String    @id @default(uuid())
  tenantId String
  nome     String
  ativo    Boolean   @default(true)
  criadoEm DateTime  @default(now())
  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  leads    Lead[]
  products Product[]
  users    User[]

  @@index([tenantId, nome])
  @@map("branches")
}

model User {
  id                       String            @id @default(uuid())
  tenantId                 String
  nome                     String
  email                    String
  senhaHash                String
  ativo                    Boolean           @default(true)
  criadoEm                 DateTime          @default(now())
  branchId                 String?
  role                     UserRole          @default(AGENT)
  whatsappNumber           String?
  passwordResetToken       String?   @unique
  passwordResetExpiry      DateTime?
  apelido                  String?
  preferences              Json?             // { theme: 'light' | 'dark' }
  recebeLeads              Boolean           @default(true)
  secretaryName            String?
  secretaryBotName         String?
  secretaryGender          String            @default("FEMININO")
  notificationSettings     Json?             // { events: string[], stages: string[] }
  uploadedProductDocuments ProductDocument[] @relation("ProductDocumentUploadedBy")
  capturedProducts         Product[]         @relation("ProductCapturedBy")
  branch                   Branch?           @relation(fields: [branchId], references: [id])
  tenant                   Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  refreshTokens            RefreshToken[]

  @@unique([tenantId, email])
  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid())
  jti       String    @unique
  userId    String
  tenantId  String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([jti])
  @@map("refresh_tokens")
}

model Lead {
  id                  String               @id @default(uuid())
  tenantId            String
  nome                String
  telefone            String?
  email               String?
  origem              String?
  status              LeadStatus           @default(NOVO)
  observacao          String?
  criadoEm            DateTime             @default(now())
  atualizadoEm        DateTime             @updatedAt
  telefoneKey         String?
  assignedUserId      String?
  branchId            String?
  lastInboundAt       DateTime?
  botPaused           Boolean              @default(false)
  deletedAt           DateTime?
  deletedBy           String?
  deletionReason      String?
  // Qualificação — preenchido pelo Assistente Operacional
  nomeCorreto              String?
  nomeCorretoOrigem        String?   // "IA" | "MANUAL"
  documents                LeadDocument[]
  participantes            LeadParticipante[]
  rendaBrutaFamiliar       Float?
  fgts                     Float?
  valorEntrada             Float?
  estadoCivil              String?
  dataNascimento           DateTime?
  // Cadastro pessoal
  cadastroOrigem           Json?     // { cpf: "IA"|null, rg: "IA"|null, ... }
  cpf                      String?
  rg                       String?
  profissao                String?
  empresa                  String?
  naturalidade             String?
  endereco                 String?
  cep                      String?
  cidade                   String?
  uf                       String?
  tempoProcurandoImovel    String?
  conversouComCorretor     Boolean?
  qualCorretorImobiliaria  String?
  perfilImovel             String?
  produtoInteresseId       String?
  resumoLead               String?
  pendingRouting      Boolean              @default(false)
  pendingRoutingScope PendingRoutingScope?
  pipelineId          String?
  stageId             String?
  aiExecutionLogs     AiExecutionLog[]
  baseFria            BaseFria?
  events              LeadEvent[]
  kbTeachings         KbTeaching[]
  leadSla             LeadSla?
  leadTransitionLogs  LeadTransitionLog[]
  branch              Branch?              @relation(fields: [branchId], references: [id])
  pipeline            Pipeline?            @relation(fields: [pipelineId], references: [id])
  stage               PipelineStage?       @relation(fields: [stageId], references: [id])
  tenant              Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reviews             ManagerReview[]

  @@index([tenantId, telefoneKey])
  @@index([tenantId, status])
  @@index([tenantId, branchId])
  @@index([tenantId, pipelineId])
  @@index([tenantId, stageId])
  @@map("leads")
}

model LeadEvent {
  id         String   @id @default(uuid())
  tenantId   String
  leadId     String
  channel    String
  isReentry  Boolean  @default(false)
  sourceRef  String?
  payloadRaw Json?
  criadoEm   DateTime @default(now())
  lead       Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, leadId])
  @@index([tenantId, channel])
  @@map("lead_events")
}

model ManagerDecisionReason {
  id           String          @id @default(uuid())
  tenantId     String
  label        String
  active       Boolean         @default(true)
  sortOrder    Int             @default(0)
  criadoEm     DateTime        @default(now())
  atualizadoEm DateTime        @updatedAt
  tenant       Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reviews      ManagerReview[]

  @@index([tenantId, active, sortOrder])
  @@map("manager_decision_reasons")
}

model ManagerReview {
  id            String                 @id @default(uuid())
  tenantId      String
  leadId        String
  justification String?
  managerUserId String?
  criadoEm      DateTime               @default(now())
  reasonId      String?
  decision      ManagerDecisionType
  lead          Lead                   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  reason        ManagerDecisionReason? @relation(fields: [reasonId], references: [id])
  tenant        Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, leadId])
  @@map("manager_reviews")
}

model Product {
  id                 String                    @id @default(uuid())
  tenantId           String
  branchId           String?
  title              String
  type               ProductType               @default(OUTRO)
  status             ProductStatus             @default(ACTIVE)
  registrationStatus ProductRegistrationStatus @default(CADASTRAR)
  kind               ProductKind               @default(PROPERTY)
  dealType           DealType                  @default(SALE)
  price              Decimal?                  @db.Decimal(18, 2)
  city               String?
  neighborhood       String?
  bedrooms           Int?
  bathrooms          Int?
  areaM2             Int?
  description        String?
  tags               String?
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  origin             ProductOrigin             @default(OWN)
  capturedByUserId   String?
  publicationStatus  ProductPublicationStatus  @default(DRAFT)

  // ── Identificação ──────────────────────────
  referenceCode      String?
  registrationNumber String?

  // ── Endereço ───────────────────────────────
  state              String?
  zipCode            String?
  street             String?
  streetNumber       String?
  complement         String?
  condominiumName    String?
  referencePoint     String?
  latitude           Float?
  longitude          Float?
  hideAddress        Boolean                   @default(false)

  // ── Preços e taxas ─────────────────────────
  rentPrice          Decimal?                  @db.Decimal(18, 2)
  iptu               Decimal?                  @db.Decimal(18, 2)
  condominiumFee     Decimal?                  @db.Decimal(18, 2)
  acceptsFinancing   Boolean                   @default(false)
  acceptsExchange    Boolean                   @default(false)

  // ── Características físicas ────────────────
  suites             Int?
  parkingSpaces      Int?
  builtAreaM2        Int?
  privateAreaM2      Int?
  landAreaM2         Int?
  floor              Int?
  totalFloors        Int?
  yearBuilt          Int?
  sunPosition        String?

  // ── Especificações das unidades (JSON array) ──────────────
  unitSpecs          Json                  @default("[]")

  // ── Comercialização ────────────────────────
  propertySituation  String?
  hasExclusivity     Boolean                   @default(false)
  exclusivityUntil   DateTime?
  virtualTourUrl     String?
  visitLocations     Json                  @default("[]")

  // ── Diferenciais ───────────────────────────
  internalFeatures   String[]                  @default([])
  condoFeatures      String[]                  @default([])
  standard           ProductStandard?
  furnished          ProductFurnished?
  condition          ProductCondition?

  // ── Empreendimento / Loteamento ─────────────
  developer             String?
  totalUnits            Int?
  totalTowers           Int?
  floorsPerTower        Int?
  privateAreaMinM2      Int?
  privateAreaMaxM2      Int?
  parkingMin            Int?
  parkingMax            Int?
  deliveryForecast      String?
  buyerIncomeLimit      Decimal?              @db.Decimal(18, 2)
  socialPrograms        String[]              @default([])
  unitTypes             String[]              @default([])
  technicalDescription  String?
  commercialDescription String?
  aiGeneratedFields     Json?
  // ── Valores, Preço e Condições ──────────────────────────────────────────────
  minBuyerIncome         Decimal?              @db.Decimal(18, 2)
  priceReviewDays        Int?
  acceptsFGTS                Boolean               @default(false)
  acceptsDirectFinancing     Boolean               @default(false)
  acceptsTradeIn             Boolean               @default(false)
  tradeInTypes           String[]              @default([])
  minEntryValue          Decimal?              @db.Decimal(18, 2)
  installmentEntryMonths Int?
  paymentConditions      String?

  documents          ProductDocument[]
  images             ProductImage[]
  videos             ProductVideo[]
  rooms              ProductRoom[]
  owners             ProductOwner[]
  branch             Branch?                   @relation(fields: [branchId], references: [id])
  capturedBy         User?                     @relation("ProductCapturedBy", fields: [capturedByUserId], references: [id])
  tenant             Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([tenantId, type])
  @@index([tenantId, origin])
  @@index([tenantId, origin, status])
  @@index([tenantId, city, neighborhood])
  @@index([tenantId, branchId])
  @@index([tenantId, kind])
  @@index([tenantId, dealType])
  @@index([tenantId, registrationStatus])
  @@index([tenantId, capturedByUserId])
  @@map("products")
}

model ProductImage {
  id            String            @id @default(uuid())
  tenantId      String
  productId     String
  url           String
  publicId      String?
  isPrimary     Boolean           @default(false)
  sortOrder     Int               @default(0)
  createdAt     DateTime          @default(now())
  customLabel   String?
  label         ProductImageLabel @default(OUTROS)
  publishSite   Boolean           @default(true)
  publishSocial Boolean           @default(false)
  title         String?
  aiRoomType    String?
  aiRoomLabel   String?
  aiFeatures    String[]
  aiAnalyzed    Boolean           @default(false)
  aiConfirmed   Boolean           @default(false)
  product       Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  tenant        Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, productId])
  @@map("product_images")
}

model ProductVideo {
  id            String   @id @default(uuid())
  tenantId      String
  productId     String
  url           String
  title         String?
  publishSite   Boolean  @default(true)
  publishSocial Boolean  @default(false)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, productId])
  @@map("product_videos")
}

model ProductDocument {
  id               String                  @id @default(uuid())
  tenantId         String
  productId        String
  url              String
  publicId         String
  title            String?
  type             ProductDocumentType     @default(OUTROS)
  visibility       ProductDocVisibility    @default(INTERNAL)
  aiExtractable    Boolean                 @default(true)
  versionLabel     String?
  uploadedByUserId String?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  category         ProductDocumentCategory @default(OTHER)
  notes            String?
  product          Product                 @relation(fields: [productId], references: [id], onDelete: Cascade)
  tenant           Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  uploadedBy       User?                   @relation("ProductDocumentUploadedBy", fields: [uploadedByUserId], references: [id])

  @@index([tenantId, productId])
  @@index([tenantId, category])
  @@index([tenantId, type])
  @@index([tenantId, visibility])
  @@index([tenantId, productId, category])
  @@index([tenantId, productId, type])
  @@map("product_documents")
}

model LeadSla {
  id            String    @id @default(uuid())
  tenantId      String
  leadId        String    @unique
  lastInboundAt DateTime?
  frozenUntil   DateTime?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lead          Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, isActive])
  @@map("lead_slas")
}

model BaseFria {
  id        String   @id @default(uuid())
  tenantId  String
  leadId    String   @unique
  reason    String?
  movedAt   DateTime @default(now())
  createdAt DateTime @default(now())
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, movedAt])
  @@map("base_fria")
}

model LeadTransitionLog {
  id        String   @id @default(uuid())
  tenantId  String
  leadId    String
  fromStage String?
  toStage   String
  changedBy String?
  createdAt DateTime @default(now())
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, leadId])
  @@index([tenantId, createdAt])
  @@map("lead_transition_logs")
}

model SlaRule {
  id              String        @id @default(uuid())
  tenantId        String
  stageId         String
  name            String
  active          Boolean       @default(true)
  dueAfterMinutes Int
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  stage           PipelineStage @relation(fields: [stageId], references: [id], onDelete: Cascade)
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, stageId])
  @@index([tenantId, active])
  @@index([tenantId, dueAfterMinutes])
  @@map("sla_rules")
}

model AiAgent {
  id               String               @id @default(uuid())
  tenantId         String
  title            String
  slug             String
  description      String?
  objective        String?
  prompt           String
  exampleOutput    String?
  mode             AiAgentMode          @default(COPILOT)
  audience         String?
  permissions      String[]             @default([])
  active           Boolean              @default(true)
  version          Int                  @default(1)
  model            String?
  temperature      Float?
  agentType        String               @default("CONVERSACIONAL")
  isOrchestrator   Boolean              @default(false)
  parentAgentId    String?
  routingKeywords  String[]             @default([])
  templateId       String?
  isCustomized     Boolean              @default(false)
  syncedAt         DateTime?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  knowledgeBases   AgentKnowledgeBase[]
  tools            AgentTool[]
  tenant           Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  template         AgentTemplate?       @relation(fields: [templateId], references: [id], onDelete: SetNull)
  executionLogs    AiExecutionLog[]
  learnings        Learning[]
  parent           AiAgent?             @relation("AgentHierarchy", fields: [parentAgentId], references: [id])
  children         AiAgent[]            @relation("AgentHierarchy")

  @@unique([tenantId, slug], name: "tenantId_slug")
  @@index([tenantId, active])
  @@index([tenantId, mode])
  @@index([tenantId, parentAgentId])
  @@index([templateId])
  @@map("ai_agents")
}

model AgentTemplate {
  id              String      @id @default(uuid())
  title           String
  slug            String      @unique
  description     String?
  objective       String?
  prompt          String
  exampleOutput   String?
  mode            AiAgentMode @default(COPILOT)
  audience        String?
  permissions     String[]    @default([])
  active          Boolean     @default(true)
  model           String?
  temperature     Float?
  isOrchestrator  Boolean     @default(false)
  routingKeywords String[]    @default([])
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  agents          AiAgent[]
  tools           AgentTemplateTool[]

  @@map("agent_templates")
}

model AgentTemplateTool {
  id            String        @id @default(uuid())
  templateId    String
  name          String
  label         String
  description   String
  type          AgentToolType @default(WEBHOOK)
  webhookUrl    String?
  webhookMethod String        @default("POST")
  active        Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  template      AgentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
  @@map("agent_template_tools")
}

model KnowledgeBase {
  id               String                @id @default(uuid())
  tenantId         String
  title            String
  type             KnowledgeBaseType
  customCategory   String?
  prompt           String
  whatAiUnderstood String?
  exampleOutput    String?
  tags             String[]
  active           Boolean               @default(true)
  priority         Int                   @default(0)
  version          Int                   @default(1)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  audience         KnowledgeBaseAudience @default(AMBOS)
  agents           AgentKnowledgeBase[]
  documents        KnowledgeBaseDocument[]
  videos           KnowledgeBaseVideo[]
  kbLinks          KnowledgeBaseLink[]
  teachings        KbTeaching[]
  tenant           Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, type])
  @@index([tenantId, active, priority])
  @@map("knowledge_bases")
}

model KbTeaching {
  id               String        @id @default(uuid())
  tenantId         String
  knowledgeBaseId  String
  leadId           String?
  leadMessage      String?
  approvedResponse String
  title            String
  createdBy        String
  replacedBy       String?
  replacedAt       DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  knowledgeBase    KnowledgeBase @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  lead             Lead?         @relation(fields: [leadId], references: [id], onDelete: SetNull)
  tenant           Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, knowledgeBaseId])
  @@map("kb_teachings")
}

model KnowledgeBaseDocument {
  id              String        @id @default(uuid())
  tenantId        String
  knowledgeBaseId String
  url             String
  publicId        String
  title           String?
  extractedText   String?
  createdAt       DateTime      @default(now())
  knowledgeBase   KnowledgeBase @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, knowledgeBaseId])
  @@map("knowledge_base_documents")
}

model KnowledgeBaseVideo {
  id              String        @id @default(uuid())
  tenantId        String
  knowledgeBaseId String
  url             String
  title           String?
  description     String?
  createdAt       DateTime      @default(now())
  knowledgeBase   KnowledgeBase @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, knowledgeBaseId])
  @@map("knowledge_base_videos")
}

model KnowledgeBaseLink {
  id              String        @id @default(uuid())
  tenantId        String
  knowledgeBaseId String
  url             String
  title           String?
  description     String?
  createdAt       DateTime      @default(now())
  knowledgeBase   KnowledgeBase @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

