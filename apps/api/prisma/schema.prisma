  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([agentId, knowledgeBaseId], name: "agentId_knowledgeBaseId")
  @@index([tenantId, agentId])
  @@index([tenantId, knowledgeBaseId])
  @@map("agent_knowledge_bases")
}

model Learning {
  id            String             @id @default(uuid())
  tenantId      String
  title         String
  content       String
  aiSuggestion  String?
  sourceType    LearningSourceType
  status        LearningStatus     @default(PENDING)
  targetAgentId String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  targetAgent   AiAgent?           @relation(fields: [targetAgentId], references: [id])
  tenant        Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([tenantId, sourceType])
  @@index([tenantId, targetAgentId])
  @@map("learnings")
}

model AiExecutionLog {
  id             String      @id @default(uuid())
  tenantId       String
  agentId        String
  leadId         String?
  inputText      String
  outputText     String?
  suggestedStage String?
  confidence     Decimal?    @db.Decimal(5, 2)
  mode           AiAgentMode
  modelUsed      String?
  createdAt      DateTime    @default(now())
  agent          AiAgent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  lead           Lead?       @relation(fields: [leadId], references: [id])
  tenant         Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, agentId])
  @@index([tenantId, leadId])
  @@index([tenantId, createdAt])
  @@map("ai_execution_logs")
}

