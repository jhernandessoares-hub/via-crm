// Histórico de atualizações da demanda (tipo comentário de ticket) — o relato
// original (observacoes/tipo/local) nunca é editado depois de criado;
// qualquer novidade sobre o atendimento vira um andamento novo, sem apagar
// o que já foi registrado.
model PreOcupacaoOcorrenciaAndamento {
  id           String   @id @default(uuid())
