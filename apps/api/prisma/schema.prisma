  comprador         String? // nome do comprador
  balconyType       String?   @default("NONE") // NONE, JULIET, STANDARD (sem sacada, sacada julieta, sacada padrão)
  windowLayout      Json? // Posições e tamanhos das janelas para renderização 3D
  loteNum           String? // identificador do lote (ex: "L01", "Lote 15") — para HORIZONTAL
  loteAreaM2        Float? // área real do lote em m²
  loteFrente        Float? // dimensão de frente em metros
  loteFundo         Float? // dimensão de fundo em metros
  soldAt            DateTime?
  propostaPagamento String? // forma de pagamento da proposta (FINANCIAMENTO | FGTS | A_VISTA | CONSORCIO)
  propostaObs       String? // observações livres da proposta
  leadId            String? // FK para o lead do comprador/interessado
  lead              Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  pne               Boolean   @default(false) // unidade adaptada para PNE
  ativo             Boolean   @default(true) // false = inativo/removido do espelho (não deletado fisicamente)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

