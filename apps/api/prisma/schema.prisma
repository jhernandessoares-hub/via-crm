  nome        String
  mimeType    String?
  legenda     String?
  criadoEm    DateTime             @default(now())

  atividade PreOcupacaoAtividade @relation(fields: [atividadeId], references: [id], onDelete: Cascade)

  @@index([atividadeId])
  @@map("pre_ocupacao_atividade_anexos")
}

model PreOcupacaoAtividadeParticipante {
