model AgentKnowledgeBase {
  id              String        @id @default(uuid())
  tenantId        String
  agentId         String
  knowledgeBaseId String
  createdAt       DateTime      @default(now())
  agent           AiAgent       @relation(fields: [agentId], references: [id], onDelete: Cascade)
