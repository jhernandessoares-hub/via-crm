  ocorrencia PreOcupacaoOcorrencia        @relation(fields: [ocorrenciaId], references: [id], onDelete: Cascade)
  anexos     PreOcupacaoOcorrenciaAnexo[]

  @@index([ocorrenciaId])
  @@map("pre_ocupacao_ocorrencia_andamentos")
}

